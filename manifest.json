{
  "manifest_version": 3,
  "name": "Audio EQ & Visualizer",
  "version": "1.3",
  "permissions": ["tabCapture", "offscreen", "tabs"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  }
}